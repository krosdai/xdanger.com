---
import PageLayout from "@/layouts/Base.astro";

const meta = {
  description: "Oops! It looks like this page is lost in space!",
  title: "Oops! You found a missing page!",
};
---

<PageLayout meta={meta}>
  <section class="page-section pt-0">
    <div class="page-shell">
      <h1 class="page-title mb-8">404 &middot; not found</h1>
      <p class="mb-2 text-base">oops ... something went wrong</p>
      <p class="text-base">
        please <a class="cactus-link" href="/">head back home</a> to find your way.
      </p>
    </div>
  </section>
</PageLayout>
