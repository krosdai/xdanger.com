<script>
  // Progressive enhancement: resolve each token to a hex/rgb string for the
  // current theme, click-to-copy token names, and keep values fresh on theme
  // toggle. The page is fully usable without this — chips already preview live
  // via CSS vars.
  const root = document.documentElement;
  const probe = document.createElement("span");
  probe.style.cssText = "position:absolute;width:0;height:0;visibility:hidden";
  document.body.appendChild(probe);
  const pc = document.createElement("canvas");
  pc.width = pc.height = 1;
  const pctx = pc.getContext("2d", { willReadFrequently: true })!;

  function resolve(varName: string) {
    probe.style.background = "transparent";
    probe.style.background = `var(${varName})`;
    const cs = getComputedStyle(probe).backgroundColor;
    pctx.clearRect(0, 0, 1, 1);
    pctx.fillStyle = "rgba(0,0,0,0)";
    pctx.fillStyle = cs;
    pctx.fillRect(0, 0, 1, 1);
    const d = pctx.getImageData(0, 0, 1, 1).data;
    return { r: d[0], g: d[1], b: d[2], a: +(d[3] / 255).toFixed(2) };
  }
  const hx = (n: number) => n.toString(16).padStart(2, "0");
  function fmt(varName: string) {
    const c = resolve(varName);
    if (c.a >= 0.999) return `#${hx(c.r)}${hx(c.g)}${hx(c.b)}`.toUpperCase();
    return `rgb(${c.r} ${c.g} ${c.b} / ${c.a})`;
  }

  const valEls = Array.from(document.querySelectorAll<HTMLElement>(".ds-val"));
  function refresh() {
    for (const el of valEls) {
      const name = el.getAttribute("data-val-for");
      if (name) el.textContent = fmt(name);
    }
  }
  refresh();

  const toast = document.getElementById("ds-toast")!;
  let toastTimer: ReturnType<typeof setTimeout>;
  function copy(text: string, label?: string) {
    navigator.clipboard?.writeText(text);
    toast.textContent = label ?? `copied  ${text}`;
    toast.classList.add("show");
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove("show"), 1600);
  }

  for (const el of document.querySelectorAll<HTMLElement>("[data-token]")) {
    el.addEventListener("click", () => {
      const t = el.getAttribute("data-token")!;
      copy(`var(${t})`, `copied  var(${t})`);
    });
  }

  // Re-resolve values when the theme attribute flips.
  new MutationObserver(refresh).observe(root, {
    attributeFilter: ["data-theme"],
    attributes: true,
  });
</script>
