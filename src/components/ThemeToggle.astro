---
/**
 * Theme toggle — the bordered circular "icon-btn" look lifted from the design
 * system reference: a radius-full chip with a hairline border, ink-muted sun /
 * moon glyph that turns accent (border + icon together) on hover. Sun shows in
 * light, crescent moon in dark, swapped via the `dark:` variant (mapped to
 * `data-theme` in global.css). The site's own theme-change mechanism (custom
 * event → ThemeProvider) and the header's scroll-collapse sizing are preserved.
 */
---

<theme-toggle class="flex flex-col">
  <button
    class="text-ink-muted hover:text-accent hover:border-accent border-line-strong focus-visible:outline-accent grid size-[34px] shrink-0 cursor-pointer place-items-center rounded-full border transition-colors focus-visible:outline-2 focus-visible:outline-offset-2"
    type="button"
  >
    <span class="sr-only">Toggle theme</span>
    <svg
      aria-hidden="true"
      class="block size-[18px] dark:hidden"
      fill="none"
      focusable="false"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-width="1.6"
      viewBox="0 0 24 24"
    >
      <circle cx="12" cy="12" r="4.2"></circle>
      <path
        d="M12 2.5v2.4M12 19.1v2.4M4.6 4.6l1.7 1.7M17.7 17.7l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.6 19.4l1.7-1.7M17.7 6.3l1.7-1.7"
      ></path>
    </svg>
    <svg
      aria-hidden="true"
      class="hidden size-[18px] dark:block"
      fill="none"
      focusable="false"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.6"
      viewBox="0 0 24 24"
    >
      <path d="M20 14.5A8 8 0 1 1 9.5 4a6.3 6.3 0 0 0 10.5 10.5z"></path>
    </svg>
  </button>
</theme-toggle>

<script>
  import { rootInDarkMode } from "@/utils/domElement";

  class ThemeToggle extends HTMLElement {
    private themeObserver?: MutationObserver;

    constructor() {
      super();
      const button = this.querySelector<HTMLButtonElement>("button");

      if (button) {
        const setLabel = () => {
          button.setAttribute(
            "aria-label",
            rootInDarkMode() ? "Switch to light theme" : "Switch to dark theme",
          );
        };

        setLabel();
        this.themeObserver = new MutationObserver(setLabel);
        this.themeObserver.observe(document.documentElement, {
          attributeFilter: ["data-theme"],
          attributes: true,
        });
        button.addEventListener("click", () => {
          const nextTheme = rootInDarkMode() ? "light" : "dark";
          const themeChangeEvent = new CustomEvent("theme-change", {
            detail: {
              theme: nextTheme,
            },
          });
          document.dispatchEvent(themeChangeEvent);
        });
      } else {
        console.warn("Theme Toggle: No button found");
      }
    }

    disconnectedCallback() {
      this.themeObserver?.disconnect();
    }
  }

  customElements.define("theme-toggle", ThemeToggle);
</script>
