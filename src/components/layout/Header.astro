---
import ThemeToggle from "@/components/ThemeToggle.astro";
import { siteConfig } from "@/site.config";

// Mark the nav link for the section the visitor is currently in — `/posts` (and
// its paginated/article children) or `/notes`. Pure SSR off `Astro.url`, no JS.
const pathname = Astro.url.pathname.replace(/\/$/, "");
const inSection = (base: string) => pathname === base || pathname.startsWith(`${base}/`);
---

<header
  data-collapsed="false"
  id="site-header"
  class="pointer-events-none sticky top-0 z-50 w-full"
>
  <div
    class="site-header-glass bg-background/95 supports-[backdrop-filter]:bg-background/60 [[data-collapsed=true]_&]:border-foreground/10 pointer-events-auto w-full border-b-0 border-solid border-transparent transition [[data-collapsed=true]_&]:border-b"
  >
    <div class="site-header-shell page-shell relative z-10 flex items-start justify-between gap-4">
      <div>
        <p class="site-header-title text-accent-2 font-serif-medium leading-none font-medium">
          <a href="/" data-astro-prefetch>{siteConfig.author}</a>
        </p>
        <p
          class="site-header-tagline note text-muted max-w-2xl overflow-hidden leading-relaxed max-sm:hidden"
        >
          Notes on tech, products, and life.
        </p>
      </div>
      <div class="site-header-actions flex items-center gap-6">
        <nav class="site-header-nav flex items-center gap-4 text-base" aria-label="Primary">
          <a href="/posts" data-astro-prefetch aria-current={inSection("/posts") ? "page" : undefined}
            >writings</a
          >
          <a href="/notes" data-astro-prefetch aria-current={inSection("/notes") ? "page" : undefined}
            >notes</a
          >
        </nav>
        <slot name="nav" />
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<style>
  /* Primary nav opts out of the chrome `Style A` (no-underline) link treatment
     and back into the body `Style B`: a faint 1px underline that firms up to the
     accent colour on hover, matching the prose links in the page body. Scoped,
     so the `data-astro-cid` attribute outweighs global.css's `:is(header) a`. */
  .site-header-nav a {
    text-decoration-line: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    text-decoration-color: color-mix(in oklab, currentColor 30%, transparent);
  }
  .site-header-nav a:hover {
    color: inherit;
    text-decoration-color: var(--color-accent);
  }
  /* "You are here": the link for the current section reads in the accent colour
     with a firm accent underline, so /posts and /notes don't sit in identical
     resting styles. */
  .site-header-nav a[aria-current="page"] {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }

  #site-header {
    --header-collapse-offset: 0px;
    --header-padding-y: 3rem;
    --header-padding-y-sm: 4.5rem;
    --header-padding-y-md: 6rem;
    --header-tagline-margin-top: 0.25rem;
    --header-tagline-max-height: 2rem;
    --header-tagline-opacity: 1;

    margin-bottom: var(--header-collapse-offset);
  }

  /*
   * Frosted-glass material: a 6px backdrop blur frosts content scrolling
   * underneath. (Two earlier flourishes were dropped because they made the
   * expanded header read differently from the body at the top of the page,
   * where nothing sits behind the glass for them to act on: a saturate(180%)
   * boost amplified the uniform background's chroma, and an inset 1px rim
   * highlight drew a faint light line along the top edge — both showed up as a
   * seam against the body in dark mode.)
   *
   * This is deliberately *not* Apple's Liquid Glass: true refraction needs an
   * SVG filter fed into backdrop-filter, which WebKit/Safari (iOS & macOS) does
   * not support — so the effect tops out at frosted glass on our target OSes.
   * Browsers without backdrop-filter fall back to the bg-background/95 tint.
   */
  .site-header-glass {
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    /*
     * A drop shadow that stays invisible until the header collapses, when it
     * lifts the bar a hair off the content below. The element carries Tailwind's
     * `transition` utility (not `transition-colors`) so this box-shadow fades in
     * on collapse instead of popping — the drop layer interpolates from
     * transparent to its lifted value.
     */
    --header-glass-drop: 0 0 #0000;
    box-shadow: var(--header-glass-drop);
  }

  :global([data-collapsed="true"]) .site-header-glass {
    --header-glass-drop: 0 1px 3px 0 oklch(0% 0 0 / 0.07);
  }

  :global([data-theme="dark"] [data-collapsed="true"]) .site-header-glass {
    --header-glass-drop: 0 1px 4px 0 oklch(0% 0 0 / 0.32);
  }

  .site-header-shell {
    padding-block: var(--header-padding-y);
  }

  /* Collapsed bar mirrors the design-system topbar: the 34px icon-btn toggle
     pins the row height and the shrunk title sits vertically centered against
     it. The expanded masthead keeps `items-start` so the toggle aligns to the
     title's top line above the tagline. */
  :global(#site-header[data-collapsed="true"]) .site-header-shell {
    align-items: center;
  }

  .site-header-tagline {
    /* Bump one step over .note's 13px; the scoped selector outweighs the utility. */
    font-size: 14px;
    margin-top: var(--header-tagline-margin-top);
    max-height: var(--header-tagline-max-height);
    opacity: var(--header-tagline-opacity);
  }

  /* Mobile (< sm) keeps the title at text-xl and never shrinks it further. */
  .site-header-title {
    font-size: 1.25rem;
  }

  @media (min-width: 640px) {
    .site-header-shell {
      padding-block: var(--header-padding-y-sm);
    }

    /* sm+ : the title stays text-2xl through the whole scroll-linked collapse,
       then eases one notch to text-xl only once the bar is fully collapsed —
       a single smooth transition at the final stage rather than a size that
       tracks scroll position frame-by-frame (which read as abrupt). */
    .site-header-title {
      font-size: 1.5rem;
      transition: font-size 500ms ease;
    }
    :global(#site-header[data-collapsed="true"]) .site-header-title {
      font-size: 1.25rem;
    }
  }

  /* Hold the title-shrink transition still while the script samples collapse
     geometry, and honor reduced-motion. (The toggle no longer resizes on
     collapse, so only the title font-size needs freezing.) */
  :global(#site-header.is-measuring) .site-header-title {
    transition: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header-title {
      transition: none;
    }
  }

  @media (min-width: 768px) {
    .site-header-shell {
      padding-block: var(--header-padding-y-md);
    }
  }
</style>

<script>
  // Collapsed bar matches the design-system topbar (59px): 12px (--space-3)
  // top/bottom padding + the 34px icon-btn toggle (which pins the row height,
  // since the title shrinks to 1.25rem) + the 1px bottom hairline.
  const COMPACT_PADDING_Y = 12;
  const COMPACT_PADDING_Y_SM = 12;
  const COMPACT_PADDING_Y_MD = 12;
  const EXPANDED_PADDING_Y = 48;
  const EXPANDED_PADDING_Y_SM = 72;
  const EXPANDED_PADDING_Y_MD = 96;
  const TAGLINE_MARGIN_TOP = 4;
  const TAGLINE_MAX_HEIGHT = 32;

  let compactScrollY = 192;
  let ticking = false;
  let measureTicking = false;

  function setHeaderExpandedness(siteHeader: HTMLElement, expandedness: number) {
    const paddingY = COMPACT_PADDING_Y + (EXPANDED_PADDING_Y - COMPACT_PADDING_Y) * expandedness;
    const paddingYSm =
      COMPACT_PADDING_Y_SM + (EXPANDED_PADDING_Y_SM - COMPACT_PADDING_Y_SM) * expandedness;
    const paddingYMd =
      COMPACT_PADDING_Y_MD + (EXPANDED_PADDING_Y_MD - COMPACT_PADDING_Y_MD) * expandedness;

    siteHeader.style.setProperty("--header-padding-y", `${paddingY}px`);
    siteHeader.style.setProperty("--header-padding-y-sm", `${paddingYSm}px`);
    siteHeader.style.setProperty("--header-padding-y-md", `${paddingYMd}px`);
    siteHeader.style.setProperty(
      "--header-tagline-margin-top",
      `${TAGLINE_MARGIN_TOP * expandedness}px`,
    );
    siteHeader.style.setProperty(
      "--header-tagline-max-height",
      `${TAGLINE_MAX_HEIGHT * expandedness}px`,
    );
    siteHeader.style.setProperty("--header-tagline-opacity", String(expandedness));
  }

  function measureHeaderCollapseDistance() {
    const siteHeader = document.getElementById("site-header") as HTMLElement | null;
    if (!siteHeader) return;

    // Measure with the title/toggle at full size (data-collapsed=false) and
    // animations frozen, so the reads are exact regardless of the live state.
    // The title shrink is a final-stage transition, so it must not count toward
    // the collapse distance (otherwise the offset would over-compensate).
    siteHeader.classList.add("is-measuring");
    siteHeader.setAttribute("data-collapsed", "false");

    siteHeader.style.setProperty("--header-collapse-offset", "0px");
    setHeaderExpandedness(siteHeader, 1);
    const expandedHeight = siteHeader.getBoundingClientRect().height;

    setHeaderExpandedness(siteHeader, 0);
    const compactHeight = siteHeader.getBoundingClientRect().height;

    siteHeader.classList.remove("is-measuring");

    compactScrollY = Math.max(expandedHeight - compactHeight, 1);
    updateHeaderCollapse();
  }

  function updateHeaderCollapse() {
    const siteHeader = document.getElementById("site-header") as HTMLElement | null;
    if (!siteHeader) return;

    const progress = Math.min(Math.max(window.scrollY / compactScrollY, 0), 1);
    const expandedness = 1 - progress;

    setHeaderExpandedness(siteHeader, expandedness);
    siteHeader.style.setProperty("--header-collapse-offset", `${compactScrollY * progress}px`);
    siteHeader.setAttribute("data-collapsed", String(progress === 1));
  }

  function scheduleHeaderCollapseUpdate() {
    if (ticking) return;

    ticking = true;
    window.requestAnimationFrame(() => {
      updateHeaderCollapse();
      ticking = false;
    });
  }

  function scheduleHeaderCollapseMeasure() {
    if (measureTicking) return;

    measureTicking = true;
    window.requestAnimationFrame(() => {
      measureHeaderCollapseDistance();
      measureTicking = false;
    });
  }

  function measureHeaderCollapseDistanceWithFonts() {
    measureHeaderCollapseDistance();
    if (document.fonts?.ready) {
      void document.fonts.ready.then(scheduleHeaderCollapseMeasure);
    }
  }

  measureHeaderCollapseDistanceWithFonts();
  document.addEventListener("scroll", scheduleHeaderCollapseUpdate, { passive: true });
  window.addEventListener("resize", scheduleHeaderCollapseMeasure);
</script>
