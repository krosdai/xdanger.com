{
  "name": "eccentric-event",
  "version": "6.2.0",
  "license": "CC-BY-SA-4.0",
  "type": "module",
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "node scripts/ensure-anyip-cert.mjs && astro dev",
    "start": "pnpm run dev",
    "cert:anyip": "node scripts/ensure-anyip-cert.mjs --force",
    "build": "pnpm run build:site && pnpm run build:search",
    "build:site": "astro build",
    "build:debug": "cross-env NODE_OPTIONS=--trace-warnings pnpm run build:site",
    "build:search": "pagefind --site dist",
    "rebuild": "pnpm run build:site",
    "rebuild:og": "cross-env REFRESH_OG_IMAGES=1 pnpm run build:site",
    "preview": "node scripts/preview-server.mjs",
    "lint": "autocorrect --lint --strict . && oxfmt --check && prettier --check --no-error-on-unmatched-pattern \"**/*.{astro,md,mdx,markdown,json,jsonc,json5,yaml,yml,html,htm,css,scss,less,vue,graphql,gql,hbs,handlebars}\" && oxlint && astro check --tsconfig tsconfig.json",
    "fix": "autocorrect --fix . && oxfmt && prettier --write --no-error-on-unmatched-pattern \"**/*.{astro,md,mdx,markdown,json,jsonc,json5,yaml,yml,html,htm,css,scss,less,vue,graphql,gql,hbs,handlebars}\" && oxlint --fix"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.2",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@tailwindcss/vite": "^4.3.0",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.4.4",
    "astro-expressive-code": "^0.42.0",
    "astro-icon": "^1.1.5",
    "astro-robots-txt": "^1.0.0",
    "astro-webmanifest": "^1.0.0",
    "cssnano": "^8.0.1",
    "hastscript": "^9.0.1",
    "mdast-util-directive": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "mdast-util-to-string": "^4.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-unwrap-images": "^1.0.0",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@iconify-json/circum": "^1.2.2",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/material-symbols-light": "^1.2.76",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/solar": "^1.2.5",
    "@pagefind/default-ui": "^1.5.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autocorrect-node": "^2.14.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "glob": "^13.0.6",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-autocorrect": "^0.4.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "reading-time": "^1.5.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
